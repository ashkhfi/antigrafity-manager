#!/usr/bin/env python3
"""
agm-web — Antigravity Manager Web Dashboard
Python stdlib HTTP server + single-page app.
Zero external dependencies.

Usage:
  agm-web              Start on port 8877
  agm-web --port 3000  Custom port
  agm-web --open       Open browser automatically
"""
import sys
from pathlib import Path

# ── Version ──
VERSION_FILE = Path(__file__).resolve().parent / "VERSION"
try:
    VERSION = VERSION_FILE.read_text().strip().split("=")[1].strip('"')
except Exception:
    VERSION = "dev"

if '--version' in sys.argv or '-v' in sys.argv:
    print(f"Antigrafity Manager v{VERSION}")
    sys.exit(0)

# Add script directory to path
SCRIPT_DIR = Path(__file__).parent
sys.path.insert(0, str(SCRIPT_DIR))

# Import and run the backend
from agm_backend import main

if __name__ == "__main__":
    main()
