#!/usr/bin/env python3
VERSION = "1.2.0"
"""
Tool untuk menambah akun Antigravity baru ke JSON DB.
"""
import sys, os, json, time, shutil, re, uuid, webbrowser, html, http.server
import threading, socketserver, urllib.request, urllib.parse
from datetime import datetime, timezone
from argparse import ArgumentParser

DB_PATH = os.path.expanduser("~/.agm/accounts.json")
DEFAULT_CONSECUTIVE = 1
DEFAULT_MAX_BACKUPS = 5


def _load_db():
    if os.path.exists(DB_PATH):
        with open(DB_PATH, "r") as f:
            return json.load(f)
    return {"version": 3, "accounts": [], "current_email": ""}


def _save_db(db):
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    with open(DB_PATH, "w") as f:
        json.dump(db, f, indent=2)


def _gen_id(): return uuid.uuid4().hex[:12]


def add_account(code):
    """Tambahkan akun dari authorization code."""
    code = code.strip().strip("'\"")
    db = _load_db()

    auth_code = urllib.parse.quote(code, safe='')
    CLIENT_ID = os.environ.get("AGM_CLIENT_ID", "PLACEHOLDER_ID")
    CLIENT_SECRET = os.environ.get("AGM_CLIENT_SECRET", "PLACEHOLDER_SECRET")
    redirect_uri = "http://localhost:18923/callback"

    data = urllib.parse.urlencode({
        "code": auth_code, "client_id": CLIENT_ID,
        "client_secret": CLIENT_SECRET,
        "redirect_uri": redirect_uri, "grant_type": "authorization_code"
    }).encode()
    req = urllib.request.Request(
        "https://oauth2.googleapis.com/token", data,
        {"Content-Type": "application/x-www-form-urlencoded"}
    )
    try:
        resp = urllib.request.urlopen(req)
        tokens = json.loads(resp.read().decode())
    except Exception as e:
        print(f"[ERROR] Gagal tukar code: {e}")
        return

    access_token = tokens.get("access_token")
    refresh_token = tokens.get("refresh_token")
    if not access_token:
        print("[ERROR] No access_token in response.")
        return

    try:
        req2 = urllib.request.Request(
            "https://www.googleapis.com/oauth2/v2/userinfo",
            headers={"Authorization": f"Bearer {access_token}"}
        )
        user = json.loads(urllib.request.urlopen(req2).read().decode())
        email = user.get("email", "unknown")
    except Exception as e:
        print(f"[ERROR] Gagal get user info: {e}")
        return

    existing = [a for a in db["accounts"] if a.get("email") == email]
    if existing:
        acct = existing[0]
        acct["access_token"] = access_token
        acct["refresh_token"] = refresh_token or acct.get("refresh_token")
        acct["updated_at"] = datetime.now(timezone.utc).isoformat()
        print(f"[OK] Token diperbarui untuk {email}")
    else:
        acct = {
            "id": _gen_id(), "email": email, "name": email,
            "access_token": access_token, "refresh_token": refresh_token or "",
            "expires_at": "", "is_active": True,
            "priority": len(db["accounts"]) + 1,
            "test_status": "unknown", "error_code": None,
            "project_id": "", "router_id": "",
            "updated_at": datetime.now(timezone.utc).isoformat(),
        }
        db["accounts"].append(acct)
        if not db.get("current_email"):
            db["current_email"] = email
        print(f"[OK] Akun {email} ditambahkan (id: {acct['id']})")

    _save_db(db)
    return acct


def main():
    os.environ.setdefault("TERM", "xterm")
    if "--version" in sys.argv:
        print(VERSION)
        return
    if len(sys.argv) > 1:
        input_str = " ".join(sys.argv[1:])
        code = input_str.strip()
        if not code:
            print("[ERROR] Masukkan authorization code.")
            sys.exit(1)
        add_account(code)
    else:
        print(f"AGM Account Manager v{VERSION}")
        print("Gunakan: ag <authorization_code>")
        sys.exit(1)


if __name__ == "__main__":
    main()
