def extract_code_from_url_or_raw(input_str):
    """Ekstrak auth code dari URL redirect atau code mentah."""
    input_str = input_str.strip()

    # Coba parse sebagai URL
    if input_str.startswith("http"):
        parsed = urlparse(input_str)
        qs = parse_qs(parsed.query)
        if "code" in qs:
            return qs["code"][0]

    # Coba parse sebagai code mentah
    if len(input_str) > 10 and not " " in input_str:
        return input_str

    return None

class CallbackHandler(http.server.BaseHTTPRequestHandler):
    """Handler untuk menerima callback OAuth."""
    auth_code = None

    def do_GET(self):
        qs = parse_qs(urlparse(self.path).query)
        if "code" in qs:
            CallbackHandler.auth_code = qs["code"][0]
            self.send_response(200)
            self.send_header("Content-Type", "text/html")
            self.end_headers()
            self.wfile.write(b"<h2>Otentikasi berhasil!</h2><p>Kembali ke terminal.</p>")
        else:
            self.send_response(400)
            self.end_headers()
            self.wfile.write(b"Missing code")

    def log_message(self, format, *args):
        pass  # Suppress log

def run_server_mode():
    """Jalankan local server untuk tangkap callback."""
    server = http.server.HTTPServer(("0.0.0.0", REDIRECT_PORT), CallbackHandler)
    server.timeout = 120
    log(f"Menunggu callback di port {REDIRECT_PORT}...")
    while CallbackHandler.auth_code is None:
        server.handle_request()
    server.server_close()
    return CallbackHandler.auth_code

def process_code(code):
    """Proses auth code: tukar token, loadCodeAssist, insert ke DB."""
    log("Menukar authorization code...")
    token_resp = exchange_code(code)

    access_token = token_resp["access_token"]
    refresh_token = token_resp.get("refresh_token", "")
    expires_in = token_resp.get("expires_in", 3599)
    now = datetime.now(timezone.utc)
    expires_at = (now.timestamp() + expires_in)
    expires_at_iso = datetime.fromtimestamp(expires_at, tz=timezone.utc).isoformat()

    log("Mengambil info user...")
    user_info = get_user_info(access_token)
    email = user_info.get("email", "unknown")
    name = user_info.get("name", email)
    log(f"User: {email} ({name})")

    log("Memanggil loadCodeAssist...")
    lca_resp = load_code_assist(access_token, email)
    project_id = ""
    if lca_resp:
        # Coba extract projectId dari response
        if isinstance(lca_resp, dict):
            project_id = lca_resp.get("cloudaicompanionProjectResourceName", "")
            if "/" in project_id:
                project_id = project_id.split("/")[-1]

    token_data = {
        "access_token": access_token,
        "refresh_token": refresh_token,
        "expires_at": expires_at_iso,
        "expires_in": expires_in,
    }

    log("Menyimpan ke DB...")
    conn_id, pid = insert_to_db(token_data, email, project_id, name)
    if not project_id:
        project_id = pid

    print()
    print(f"  \033[1;32mBerhasil ditambahkan!\033[0m")
    print(f"  ID       : {conn_id[:8]}...")
    print(f"  Email    : {email}")
    print(f"  Project  : {project_id or '(belum terdaftar)'}")
    print(f"  Status   : active")
    print()
    return conn_id

