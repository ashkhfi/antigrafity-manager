def log(msg):
    print(f"\033[32m✓\033[0m {msg}")

def err(msg):
    print(f"\033[31m✗\033[0m {msg}", file=sys.stderr)

def api_post(url, data, headers=None):
    """POST request, return parsed JSON."""
    body = urlencode(data).encode()
    h = {"Content-Type": "application/x-www-form-urlencoded"}
    if headers:
        h.update(headers)
    req = Request(url, data=body, headers=h, method="POST")
    with urlopen(req, timeout=15) as resp:
        return json.loads(resp.read())

def api_get(url, headers):
    """GET request, return parsed JSON."""
    req = Request(url, headers=headers)
    with urlopen(req, timeout=15) as resp:
        return json.loads(resp.read())

def exchange_code(code):
    """Tukar authorization code untuk tokens."""
    data = {
        "code": code,
        "client_id": CLIENT_ID,
        "client_secret": CLIENT_SECRET,
        "redirect_uri": REDIRECT_URI,
        "grant_type": "authorization_code",
    }
    return api_post(TOKEN_URL, data)

def get_user_info(access_token):
    """Ambil info user (email, nama)."""
    return api_get(USERINFO_URL, {"Authorization": f"Bearer {access_token}"})

def load_code_assist(access_token, email):
    """Panggil loadCodeAssist untuk daftarkan project antigravity."""
    body = {
        "metadata": {
            "ideType": "ANTIGRAVITY",
            "ideVersion": "1.107.0",
            "platform": "LINUX_X64",
        }
    }
    headers = {
        "Authorization": f"Bearer {access_token}",
        "Content-Type": "application/json",
        "User-Agent": "google-api-nodejs-client/9.15.1",
        "X-Goog-Api-Client": "google-cloud-sdk vscode_cloudshelleditor/0.1",
    }
    req = Request(
        LOAD_CODE_ASSIST_URL,
        data=json.dumps(body).encode(),
        headers=headers,
        method="POST",
    )
    try:
        with urlopen(req, timeout=15) as resp:
            return json.loads(resp.read())
    except Exception as e:
        # loadCodeAssist bisa gagal tapi token tetap valid
        log(f"loadCodeAssist: {e} (token tetap disimpan)")
        return None

def _load_db():
    """Load JSON DB or return empty structure."""
    if os.path.exists(DB_PATH):
        with open(DB_PATH, "r") as f:
            return json.load(f)
    return {"version": 3, "accounts": [], "current_email": ""}

def _save_db(db):
    """Write JSON DB atomically."""
    dir_path = os.path.dirname(DB_PATH)
    if dir_path:
        os.makedirs(dir_path, exist_ok=True)
    tmp = DB_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(db, f, indent=2)
    os.replace(tmp, DB_PATH)

def insert_to_db(token_data, email, project_id="", name=""):
    """Insert akun baru ke JSON DB."""
    db = _load_db()
    now = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
    account_id = hashlib.sha256(email.encode()).hexdigest()[:16]

    account = {
        "email": email,
        "name": name or email,
        "provider": "antigravity",
        "is_active": True,
        "access_token": token_data["access_token"],
        "refresh_token": token_data["refresh_token"],
        "expires_at": token_data.get("expires_at", ""),
        "scope": " ".join(SCOPES),
        "project_id": project_id,
        "test_status": "active",
        "priority": 1,
    }

    # Replace existing account with same email, or append
    accounts = db["accounts"]
    for i, acc in enumerate(accounts):
        if acc.get("email") == email:
            accounts[i] = account
            break
    else:
        accounts.append(account)

    _save_db(db)
    return account_id, project_id

