def init_colors():
    curses.start_color()
    curses.use_default_colors()
    for cid, (fg, bg) in THEME.items():
        curses.init_pair(cid, fg, bg)


def cstr(text, color_id, bold=False):
    """Create colored attribute."""
    attr = curses.color_pair(color_id)
    if bold:
        attr |= curses.A_BOLD
    return attr


def draw_box(scr, y, x, h, w, color=C_BOX):
    """Draw box with Unicode characters."""
    if y + h > curses.LINES or x + w > curses.COLS:
        return
    try:
        tl, tr, bl, br, h_, v_ = "┌", "┐", "└", "┘", "─", "│"
        attr = curses.color_pair(color)
        # Top
        scr.addstr(y, x, tl + h_ * (w - 2) + tr, attr)
        # Sides
        for i in range(1, h - 1):
            scr.addstr(y + i, x, v_, attr)
            scr.addstr(y + i, x + w - 1, v_, attr)
        # Bottom
        scr.addstr(y + h - 1, x, bl + h_ * (w - 2) + br, attr)
    except curses.error:
        pass


def draw_header(scr, text, y=0):
    """Draw header bar across screen width."""
    try:
        w = curses.COLS
        padded = f" {text} ".center(w)
        scr.addstr(y, 0, padded[: w - 1], cstr("", C_HEADER, bold=True))
    except curses.error:
        pass


def draw_statusbar(scr, text, y=None):
    """Draw status bar at bottom."""
    try:
        if y is None:
            y = curses.LINES - 1
        w = curses.COLS
        padded = f" {text} ".ljust(w)[: w - 1]
        scr.addstr(y, 0, padded, cstr("", C_STATUS, bold=True))
    except curses.error:
        pass


def draw_text(scr, y, x, text, color=C_DEFAULT, bold=False, maxlen=None):
    """Draw text at position, clipped to screen."""
    try:
        if y < 0 or y >= curses.LINES or x < 0 or x >= curses.COLS:
            return
        max_w = (maxlen or (curses.COLS - x - 1))
        display = text[:max_w]
        scr.addstr(y, x, display, cstr(display, color, bold))
    except curses.error:
        pass


def draw_notification(scr, text, color=C_SUCCESS, timeout=2):
    """Draw notification message, then sleep."""
    try:
        if curses.LINES < 3 or curses.COLS < 20:
            return
        w = min(len(text) + 4, curses.COLS - 4)
        y = curses.LINES // 2
        x = (curses.COLS - w) // 2
        draw_box(scr, y, x, 3, w, color)
        draw_text(scr, y + 1, x + 2, text[: w - 4], color, bold=True)
        scr.refresh()
        time.sleep(timeout)
    except curses.error:
        pass


def prompt_confirm(scr, text, y=None):
    """Show yes/no confirmation. Returns True/False."""
    try:
        if y is None:
            y = curses.LINES // 2
        w = min(len(text) + 8, curses.COLS - 4)
        x = (curses.COLS - w) // 2
        draw_box(scr, y, x, 5, w, C_WARN)
        draw_text(scr, y + 1, x + 2, text[: w - 4], C_WARN, bold=True)
        draw_text(scr, y + 3, x + 2, "[Y]es  [N]o", C_DEFAULT)
        scr.refresh()
        while True:
            key = scr.getch()
            if key in (ord("y"), ord("Y"), 10):
                return True
            if key in (ord("n"), ord("N"), 27):
                return False
    except curses.error:
        return False


def prompt_input(scr, text, y=None, max_input=200, mask=False):
    """Show input prompt. Returns string or None (cancelled)."""
    try:
        if y is None:
            y = curses.LINES // 2
        w = min(max(len(text) + 16, 50), curses.COLS - 4)
        x = (curses.COLS - w) // 2
        input_x = x + 2
        input_w = w - 4
        buf = ""
        cur = 0
        while True:
            draw_box(scr, y, x, 5, w, C_SELECT)
            draw_text(scr, y + 1, input_x, text[:input_w], C_SELECT, bold=True)
            display = ("*" * len(buf) if mask else buf)[:input_w]
            draw_text(scr, y + 3, input_x, display.ljust(input_w), C_DEFAULT)
            try:
                scr.move(y + 3, input_x + cur)
            except curses.error:
                pass
            scr.refresh()
            key = scr.getch()
            if key in (27,):  # Escape
                return None
            if key in (10, 13) and buf:  # Enter (LF/CR)
                return buf
            if key in (curses.KEY_BACKSPACE, 127, 8):
                if cur > 0:
                    buf = buf[:cur - 1] + buf[cur:]
                    cur -= 1
            elif 32 <= key < 256:
                if cur < max_input:
                    buf = buf[:cur] + chr(key) + buf[cur:]
                    cur += 1
            elif key == curses.KEY_LEFT and cur > 0:
                cur -= 1
            elif key == curses.KEY_RIGHT and cur < len(buf):
                cur += 1
    except curses.error:
        return None


