# ─────────────────────────────────────────────
# Token Rotation (for agy wrapper)
# ─────────────────────────────────────────────
def rotate_for_agy():
    """Pick best token and write to token file. Returns (success, msg)."""
    db = Database()
    tokens = db.get_active_tokens()
    if not tokens:
        return False, "Tidak ada token aktif"

    now = datetime.now(timezone.utc)
    best = None
    for t in tokens:
        exp = t.get("expires_at", "")
        if not exp:
            best = t
            continue
        try:
            exp_dt = datetime.fromisoformat(exp.replace("Z", "+00:00"))
            if exp_dt > now + timedelta(seconds=60):
                if best is None:
                    best = t
        except (ValueError, TypeError):
            pass

    if not best:
        return False, "Semua token expired"

    payload = {
        "token": {
            "access_token": best["access_token"],
            "token_type": "Bearer",
            "refresh_token": best.get("refresh_token", ""),
            "expiry": best.get("expires_at", ""),
        },
        "auth_method": "consumer",
    }
    TOKEN_FILE.parent.mkdir(parents=True, exist_ok=True)
    TOKEN_FILE.write_text(json.dumps(payload))
    return True, f"Token → {best.get('email', 'unknown')}"


def mark_unavailable(access_token, error_msg=""):
    """Mark token as unavailable in DB."""
    db = Database()
    for acc in db.list_accounts():
        if acc.get("access_token") == access_token:
            db.update_account(acc["id"], {
                "test_status": "unavailable",
                "last_error": error_msg,
                "last_error_at": db._now(),
            })
            return True
    return False


