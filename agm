class Database:
    """JSON-based account store with atomic writes."""

    def __init__(self, path=DB_PATH):
        self.path = Path(path)
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self._data = self._load()

    def _load(self):
        if self.path.exists():
            try:
                raw = json.loads(self.path.read_text())
                if raw.get("version") != DB_VERSION:
                    raw = self._migrate(raw)
                return raw
            except (json.JSONDecodeError, OSError) as e:
                # Backup corrupted file
                bak = self.path.with_suffix(".json.corrupt")
                try:
                    self.path.rename(bak)
                except OSError:
                    pass
                return self._empty()
        return self._empty()

    def _empty(self):
        return {
            "version": DB_VERSION,
            "accounts": [],
            "settings": {
                "max_backups": 5,
                "auto_rotate": True,
            },
        }

    def _migrate(self, old):
        """Migrate from older DB versions."""
        data = self._empty()
        if "accounts" in old:
            for acc in old["accounts"]:
                acc.setdefault("id", self._gen_id(acc.get("email", "")))
                acc.setdefault("priority", len(data["accounts"]) + 1)
                data["accounts"].append(acc)
        self._save(data)
        return data

    def _save(self, data=None):
        if data is None:
            data = self._data
        tmp = self.path.with_suffix(".json.tmp")
        try:
            tmp.write_text(json.dumps(data, indent=2, ensure_ascii=False))
            tmp.rename(self.path)
        except OSError as e:
            raise RuntimeError(f"Gagal simpan DB: {e}")

    def _now(self):
        return datetime.now(timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z")

    def _gen_id(self, email):
        return hashlib.md5(email.encode()).hexdigest()[:12]

    def list_accounts(self, provider="antigravity"):
        return [a for a in self._data["accounts"] if a.get("provider") == provider]

    def get_account(self, account_id):
        for a in self._data["accounts"]:
            if a.get("id") == account_id:
                return a
        return None

    def get_account_by_email(self, email):
        for a in self._data["accounts"]:
            if a.get("email") == email:
                return a
        return None

    def add_account(self, account):
        """Add or update account. Returns (account, is_new)."""
        existing = self.get_account_by_email(account.get("email"))
        if existing:
            existing.update({k: v for k, v in account.items() if v is not None})
            existing["updated_at"] = self._now()
            self._save()
            return existing, False
        account["id"] = self._gen_id(account.get("email", str(time.time())))
        account.setdefault("created_at", self._now())
        account.setdefault("updated_at", self._now())
        account.setdefault("priority", len(self._data["accounts"]) + 1)
        self._data["accounts"].append(account)
        self._save()
        return account, True

    def update_account(self, account_id, updates):
        acc = self.get_account(account_id)
        if not acc:
            return None
        acc.update(updates)
        acc["updated_at"] = self._now()
        self._save()
        return acc

    def delete_account(self, account_id):
        before = len(self._data["accounts"])
        self._data["accounts"] = [
            a for a in self._data["accounts"] if a.get("id") != account_id
        ]
        if len(self._data["accounts"]) < before:
            self._save()
            return True
        return False

    def toggle_active(self, account_id):
        acc = self.get_account(account_id)
        if not acc:
            return None
        acc["is_active"] = not acc.get("is_active", True)
        acc["updated_at"] = self._now()
        self._save()
        return acc

    def stats(self):
        accounts = self.list_accounts()
        active = sum(1 for a in accounts if a.get("is_active", True))
        now = datetime.now(timezone.utc)
        healthy = 0
        expiring = 0
        expired = 0
        for a in accounts:
            exp = a.get("expires_at")
            if not exp:
                continue
            try:
                exp_dt = datetime.fromisoformat(exp.replace("Z", "+00:00"))
                diff = (exp_dt - now).total_seconds()
                if diff > 600:
                    healthy += 1
                elif diff > 0:
                    expiring += 1
                else:
                    expired += 1
            except (ValueError, TypeError):
                pass
        return {
            "total": len(accounts),
            "active": active,
            "inactive": len(accounts) - active,
            "healthy": healthy,
            "expiring": expiring,
            "expired": expired,
        }

    def sync_from_router(self):
        """Import accounts from 9router SQLite DB (optional)."""
        if not ROUTER_DB.exists():
            return 0, "9router DB not available — standalone mode"

        import sqlite3
        try:
            conn = sqlite3.connect(str(ROUTER_DB))
            conn.row_factory = sqlite3.Row
            rows = conn.execute(
                "SELECT id, email, name, priority, isActive, data, createdAt, updatedAt "
                "FROM providerConnections WHERE provider='antigravity'"
            ).fetchall()
            conn.close()
        except Exception as e:
            return 0, f"Gagal baca 9router DB: {e}"

        count = 0
        for row in rows:
            data = json.loads(row["data"])
            account = {
                "email": row["email"] or "",
                "name": row["name"] or row["email"] or "",
                "provider": "antigravity",
                "is_active": bool(row["isActive"]),
                "priority": row["priority"] or 99,
                "access_token": data.get("accessToken", ""),
                "refresh_token": data.get("refreshToken", ""),
                "expires_at": data.get("expiresAt", ""),
                "scope": data.get("scope", ""),
                "project_id": data.get("projectId", ""),
                "test_status": data.get("testStatus", "unknown"),
                "error_code": data.get("errorCode"),
                "last_error": data.get("lastError"),
                "last_used_at": data.get("lastUsedAt"),
                "router_id": row["id"],
                "created_at": row["createdAt"],
                "updated_at": row["updatedAt"],
            }
            self.add_account(account)
            count += 1
        return count, f"Sync {count} akun dari 9router"

    def get_active_tokens(self):
        """Get active tokens sorted by priority."""
        accounts = self.list_accounts()
        active = [a for a in accounts if a.get("is_active", True) and a.get("access_token")]
        active.sort(key=lambda a: a.get("priority", 99))
        return active


