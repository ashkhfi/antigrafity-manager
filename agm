    def handle_key(self, key):
        accounts = self.get_filtered()

        if self.detail_mode:
            if key in (27, ord("q"), ord("Q"), 8):  # Esc, Q, Backspace
                self.detail_mode = False
                self.detail_account = None
                return None
            if key == ord("t") or key == ord("T"):
                if self.detail_account:
                    self.app.db.toggle_active(self.detail_account["id"])
                    self.detail_account = self.app.db.get_account(self.detail_account["id"])
                return None
            if key == ord("d") or key == ord("D"):
                if self.detail_account:
                    if prompt_confirm(self.app.scr, f"Delete {self.detail_account.get('email', '?')}?"):
                        self.app.db.delete_account(self.detail_account["id"])
                        self.detail_mode = False
                        self.detail_account = None
                        self.selected = min(self.selected, len(self.app.db.list_accounts()) - 1)
                return None
            if key == ord("c") or key == ord("C"):
                if self.detail_account and self.detail_account.get("refresh_token"):
                    token_path = Path.home() / ".agm" / "last_refresh_token.txt"
                    token_path.write_text(self.detail_account["refresh_token"])
                    draw_notification(self.app.scr, f"Refresh token saved → {token_path}", C_SUCCESS, 1)
                return None
            return None

        # List mode
        if key in (27, ord("q"), ord("Q")):
            return "back"
        if key == curses.KEY_UP and self.selected > 0:
            self.selected -= 1
        elif key == curses.KEY_DOWN and self.selected < len(accounts) - 1:
            self.selected += 1
        elif key in (10, 13) and accounts:  # Enter (LF or CR)
            self.detail_mode = True
            self.detail_account = accounts[self.selected]
        elif key == ord("t") or key == ord("T"):
            if accounts:
                self.app.db.toggle_active(accounts[self.selected]["id"])
        elif key == ord("d") or key == ord("D"):
            if accounts:
                if prompt_confirm(self.app.scr, f"Delete {accounts[self.selected].get('email', '?')}?"):
                    self.app.db.delete_account(accounts[self.selected]["id"])
                    self.selected = min(self.selected, len(self.app.db.list_accounts()) - 1)
        elif key == ord("/"):
            result = prompt_input(self.app.scr, "Search (email/project):")
            if result is not None:
                self.search_query = result
                self.selected = 0
        elif key == ord("f") or key == ord("F"):
            filters = ["all", "active", "inactive", "error"]
            idx = filters.index(self.filter_mode) if self.filter_mode in filters else 0
            self.filter_mode = filters[(idx + 1) % len(filters)]
            self.selected = 0
        return None


class AddPage(Page):
    """Add new account via Google OAuth."""

    def __init__(self, app):
        super().__init__(app)
        self.step = 0  # 0=URL, 1=input, 2=processing, 3=done/error
        self.code = ""
        self.result_msg = ""
        self.result_color = C_DEFAULT

    def draw(self):
        s = self.app.scr
        H, W = curses.LINES, curses.COLS
        draw_header(s, "ADD ACCOUNT — Google OAuth")

        y = 2
        bw = min(W - 4, 70)
        bx = (W - bw) // 2

        if self.step == 0:
            draw_box(s, y, bx, 14, bw, C_BOX)
            draw_text(s, y + 1, bx + 2, "Step 1: Open Google OAuth URL", C_BOX, bold=True)
            draw_text(s, y + 3, bx + 2, "Buka link ini di browser (HP/laptop):", C_DEFAULT)
            url = build_auth_url()
            # Wrap URL
            for i in range(0, len(url), bw - 6):
                draw_text(s, y + 4 + (i // (bw - 6)), bx + 3, url[i : i + bw - 6], C_TITLE)
            y_url = y + 4 + (len(url) // (bw - 6)) + 1
            draw_text(s, y_url + 1, bx + 2, "Setelah authorize, browser redirect ke localhost", C_DIM)
            draw_text(s, y_url + 2, bx + 2, "(yang tidak bisa diakses). Copy URL dari browser.", C_DIM)
            draw_text(s, y_url + 3, bx + 2, "Paste URL/code di langkah berikutnya.", C_DIM)
            draw_text(s, y_url + 5, bx + 2, "[Enter] Lanjut ke input code", C_SUCCESS, bold=True)

        elif self.step == 1:
            draw_box(s, y, bx, 8, bw, C_SELECT)
            draw_text(s, y + 1, bx + 2, "Step 2: Paste URL atau Authorization Code", C_SELECT, bold=True)
            draw_text(s, y + 3, bx + 2, "Paste URL redirect atau code dari browser:", C_DEFAULT)
            display = self.code[: bw - 6] if self.code else "(empty)"
            draw_text(s, y + 4, bx + 3, display, C_DEFAULT)
            draw_text(s, y + 6, bx + 2, "[Enter] Proses  [Esc] Batal", C_DEFAULT)

        elif self.step == 2:
            draw_box(s, y, bx, 5, bw, C_WARN)
            draw_text(s, y + 2, bx + 2, "⏳ Memproses authorization...", C_WARN, bold=True)

        elif self.step == 3:
            color = C_SUCCESS if "OK" in self.result_msg or "berhasil" in self.result_msg else C_ERROR
            draw_box(s, y, bx, 6, bw, color)
            draw_text(s, y + 1, bx + 2, "Hasil:", color, bold=True)
            draw_text(s, y + 3, bx + 2, self.result_msg[: bw - 6], color)
            draw_text(s, y + 4, bx + 2, "[Enter] Kembali  [A] Tambah lagi", C_DEFAULT)

    def handle_key(self, key):
        if key == 27 or key == ord("q"):
            if self.step in (0, 3):
                self.step = 0
                self.code = ""
                return "back"
            if self.step == 1:
                self.step = 0
                return None
        if self.step == 0 and key in (10, 13):
            self.step = 1
            return None
        if self.step == 1:
            if key in (10, 13) and self.code:
                self._process()
                return None
            if key in (curses.KEY_BACKSPACE, 127, 8):
                self.code = self.code[:-1]
                return None
            if 32 <= key < 256:
                self.code += chr(key)
                return None
        if self.step == 3:
            if key in (10, 13) or key == ord("a"):
                self.step = 0
                self.code = ""
                if key == ord("a"):
                    return None
                return "back"
        return None

    def _process(self):
        self.step = 2
        self.app.scr.refresh()
        try:
            code = self.code.strip()
            if code.startswith("http"):
                qs = parse_qs(urlparse(code).query)
                if "code" in qs:
                    code = qs["code"][0]

            # Exchange code for tokens
            token_data = exchange_code(code)
            access_token = token_data.get("access_token", "")
            refresh_token = token_data.get("refresh_token", "")
            expires_in = token_data.get("expires_at", 3600)
            if isinstance(expires_in, int):
                expires_at = (
                    datetime.now(timezone.utc) + timedelta(seconds=expires_in)
                ).isoformat()
            else:
                expires_at = str(expires_in)

            # Get user info
            try:
                user_info = get_user_info(access_token)
                email = user_info.get("email", "")
                name = user_info.get("name", email)
            except Exception:
                email = ""
                name = ""

            # Get project info
            project_id = ""
            try:
                ca_resp = load_code_assist(access_token)
                project_id = ca_resp.get("cloudaicompanion", {}).get("project", "")
            except Exception:
                pass

            account = {
                "email": email,
                "name": name,
                "provider": "antigravity",
                "is_active": True,
                "access_token": access_token,
                "refresh_token": refresh_token,
                "expires_at": expires_at,
                "scope": " ".join(SCOPES),
                "project_id": project_id,
                "test_status": "active",
            }
            acc, is_new = self.app.db.add_account(account)
            action = "ditambahkan" if is_new else "diupdate"
            self.result_msg = f"OK: {email} {action}. Project: {project_id}"
            self.result_color = C_SUCCESS
            self.step = 3
        except HTTPError as e:
            body = ""
            try:
                body = e.read().decode()[:100]
            except Exception:
                pass
            self.result_msg = f"HTTP {e.code}: {body}"
            self.result_color = C_ERROR
            self.step = 3
        except Exception as e:
            self.result_msg = f"Gagal: {e}"
            self.result_color = C_ERROR
            self.step = 3


class RefreshPage(Page):
    """Batch refresh all tokens."""

    def __init__(self, app):
        super().__init__(app)
        self.results = []
        self.running = False
        self.done = False

    def draw(self):
        s = self.app.scr
        H, W = curses.LINES, curses.COLS
        draw_header(s, "REFRESH TOKENS")

        accounts = self.app.db.list_accounts()
        y = 2
        draw_text(s, y, 2, f"Accounts: {len(accounts)}", C_DEFAULT, bold=True)
        y += 2

        if not self.running and not self.done:
            draw_text(s, y, 2, "Tekan [Enter] untuk refresh semua tokens", C_DIM)
            draw_text(s, y + 1, 2, "Tekan [Q/Esc] untuk kembali", C_DIM)
        elif self.running or self.done:
            max_rows = H - y - 3
            for i, (email, ok, msg) in enumerate(self.results[:max_rows]):
                icon = "✓" if ok else "✗"
                color = C_SUCCESS if ok else C_ERROR
                draw_text(s, y + i, 2, f" {icon} {email[:30]:<32} {msg[:30]}", color)
            if self.done:
                ok_count = sum(1 for _, ok, _ in self.results if ok)
                draw_text(s, y + len(self.results) + 1, 2, f"Done: {ok_count}/{len(self.results)} OK", C_SUCCESS, bold=True)

        status = "REFRESHING..." if self.running else ("DONE" if self.done else "READY")
        draw_statusbar(s, f" {status}  |  [Enter] start  [Esc/Q] back")

    def handle_key(self, key):
        if key == 27 or key == ord("q"):
            if not self.running:
                self.results = []
                self.done = False
                return "back"
        elif key in (10, 13) and not self.running and not self.done:
            self._do_refresh()
        elif key in (10, 13) and self.done:
            self.results = []
            self.done = False
        return None

    def _do_refresh(self):
        self.running = True
        self.results = []
        self.app.scr.refresh()
        accounts = self.app.db.list_accounts()
        for acc in accounts:
            email = acc.get("email", "?")
            rt = acc.get("refresh_token", "")
            at = acc.get("access_token", "")
            if not rt:
                self.results.append((email, False, "No refresh token"))
                continue
            try:
                new_data = refresh_token(rt)
                new_at = new_data.get("access_token", at)
                new_exp = new_data.get("expires_in", 3600)
                if isinstance(new_exp, int):
                    exp_at = (datetime.now(timezone.utc) + timedelta(seconds=new_exp)).isoformat()
                else:
                    exp_at = str(new_exp)
                self.app.db.update_account(acc["id"], {
                    "access_token": new_at,
                    "expires_at": exp_at,
                    "test_status": "active",
                    "last_error": None,
                })
                self.results.append((email, True, "OK"))
            except HTTPError as e:
                self.app.db.update_account(acc["id"], {
                    "test_status": "unavailable",
                    "last_error": f"HTTP {e.code}",
                    "last_error_at": self.app.db._now(),
                })
                self.results.append((email, False, f"HTTP {e.code}"))
            except Exception as e:
                self.results.append((email, False, str(e)[:30]))
            self.app.scr.refresh()
        self.running = False
        self.done = True


