class App:
    PAGES = {
        "dashboard": DashboardPage,
        "list": ListPage,
        "add": AddPage,
        "refresh": RefreshPage,
        "stats": StatsPage,
    }
    KEYS = {
        ord("d"): "dashboard",
        ord("l"): "list",
        ord("a"): "add",
        ord("r"): "refresh",
        ord("s"): "stats",
    }

    def __init__(self):
        self.db = Database()
        self.scr = None
        self.current_page = "dashboard"
        self.page = None
        self.running = True

    def run(self):
        curses.wrapper(self._main)

    def _main(self, stdscr):
        self.scr = stdscr
        init_colors()
        curses.curs_set(0)
        stdscr.timeout(-1)
        self.page = self.PAGES["dashboard"](self)

        while self.running:
            try:
                self.page.draw()
                self.scr.refresh()
            except curses.error:
                pass

            try:
                key = self.scr.getch()
            except KeyboardInterrupt:
                break

            if key == -1:
                continue

            # Global hotkeys
            if key in (ord("q"),) and self.current_page == "dashboard":
                break

            if key in self.KEYS and self.current_page != self.KEYS[key]:
                page_name = self.KEYS[key]
                self.current_page = page_name
                # Reset page state for certain pages
                if page_name == "list":
                    self.page = ListPage(self)
                elif page_name == "add":
                    self.page = AddPage(self)
                elif page_name == "refresh":
                    self.page = RefreshPage(self)
                else:
                    self.page = self.PAGES[page_name](self)
                continue

            result = self.page.handle_key(key)
            if result == "back":
                self.current_page = "dashboard"
                self.page = self.PAGES["dashboard"](self)
            elif result == "refresh":
                self.page = RefreshPage(self)
            elif result and isinstance(result, str) and result in self.PAGES:
                self.current_page = result
                self.page = self.PAGES[result](self)


