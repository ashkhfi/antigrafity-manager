#!/usr/bin/env python3
"""agy — Antigrafity Rotator CLI wrapper"""
import sys, os, subprocess, json, time, urllib.request, urllib.parse, shutil

VERSION = "1.2.0"
ORIG_NAME = "agy.orig"
AGY_ORIG = os.path.join(os.path.dirname(os.path.abspath(__file__)), ORIG_NAME)
DB_PATH = os.path.expanduser("~/.agm/accounts.json")
SETTINGS_PATH = os.path.expanduser("~/.agm/settings.json")


def _load_db():
    if os.path.exists(DB_PATH):
        with open(DB_PATH) as f:
            return json.load(f)
    return {"version": 3, "accounts": [], "current_email": ""}


def _save_db(db):
    os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    with open(DB_PATH, "w") as f:
        json.dump(db, f, indent=2)


def _load_settings():
    if os.path.exists(SETTINGS_PATH):
        with open(SETTINGS_PATH) as f:
            return json.load(f)
    return {}


def _save_settings(s):
    os.makedirs(os.path.dirname(SETTINGS_PATH), exist_ok=True)
    with open(SETTINGS_PATH, "w") as f:
        json.dump(s, f, indent=2)


def selisih_waktu(tanggal_str):
    """Hitung selisih jam dari tanggal_str ke sekarang. Negatif = expired."""
    from datetime import datetime, timezone
    if not tanggal_str:
        return None
    try:
        tgl = datetime.fromisoformat(tanggal_str)
        if tgl.tzinfo is None:
            tgl = tgl.replace(tzinfo=timezone.utc)
        return (tgl - datetime.now(timezone.utc)).total_seconds() / 3600
    except:
        return None


def rotate_to_next():
    """Pilih akun terbaik berdasarkan strategi fallback."""
    db = _load_db()
    accounts = db.get("accounts", [])
    if not accounts:
        return None

    current = db.get("current_email", "")
    settings = _load_settings()
    strategy = settings.get("fallback_strategy", "round_robin")
    consecutive = settings.get("consecutive_use_count", 1)
    max_backups = settings.get("max_backups", 5)
    auto_rotate = settings.get("auto_rotate", True)

    # Filter active accounts
    active = [a for a in accounts if a.get("is_active", False)]
    if not active:
        # fallback ke semua
        active = accounts

    if strategy == "round_robin":
        # Cari index current, pilih next
        idxs = [i for i, a in enumerate(active) if a.get("email") == current]
        if idxs:
            idx = (idxs[0] + 1) % len(active)
        else:
            idx = 0
        chosen = active[idx]
    elif strategy == "priority":
        sorted_accts = sorted(active, key=lambda a: a.get("priority", 999))
        chosen = sorted_accts[0]
    elif strategy == "random":
        import random
        chosen = random.choice(active)
    elif strategy == "least_errors":
        sorted_accts = sorted(active, key=lambda a: a.get("error_code") is not None)
        chosen = sorted_accts[0]
    elif strategy == "failover":
        # Pilih yang current, kalau error pilih next
        cur = [a for a in active if a.get("email") == current]
        if cur and not cur[0].get("error_code"):
            chosen = cur[0]
        else:
            sorted_accts = sorted(active, key=lambda a: a.get("priority", 999))
            chosen = sorted_accts[0]
    else:
        chosen = active[0]

    db["current_email"] = chosen["email"]
    _save_db(db)
    return chosen


def rotate_and_retry(args):
    """Rotate account, then retry the command."""
    chosen = rotate_to_next()
    if not chosen:
        print("[ROTATOR] No accounts available to rotate.", file=sys.stderr)
        return None
    email = chosen.get("email", "?")
    print(f"[ROTATOR] Rotated to: {email}", file=sys.stderr)

    if not os.path.exists(AGY_ORIG):
        print("[ROTATOR] Install antigravity-cli first (agy.orig not found)", file=sys.stderr)
        sys.exit(1)

    # Set env for auth
    env = os.environ.copy()
    env["ANTIGRAVITY_ACCESS_TOKEN"] = chosen.get("access_token", "")
    env["ANTIGRAVITY_REFRESH_TOKEN"] = chosen.get("refresh_token", "")

    # Build args: lewati --rotate flag
    cmd = [AGY_ORIG] + [a for a in args if a != "--rotate"]
    result = subprocess.run(cmd, env=env)
    return result


def status():
    """Show status of all accounts with colors."""
    db = _load_db()
    accounts = db.get("accounts", [])
    current = db.get("current_email", "")

    # Check agy.orig
    orig_ok = os.path.exists(AGY_ORIG) and os.access(AGY_ORIG, os.X_OK)

    print(f"AGM Rotator v{VERSION}")
    print(f"agy.orig: {'✓' if orig_ok else '✗ not found'}")
    print(f"Accounts: {len(accounts)} | Active: {sum(1 for a in accounts if a.get('is_active'))}")
    print(f"Current: {current or '—'}\n")
    for a in accounts:
        mark = "→" if a.get("email") == current else " "
        active = "✓" if a.get("is_active") else "✗"
        status_ = a.get("test_status", "?")
        err = a.get("error_code") or ""
        hl = selisih_waktu(a.get("expires_at"))
        hl_str = f"{hl:.0f}h" if hl is not None else "?h"
        print(f" {mark} [{active}] {a['email']:35s} {status_:12s} {hl_str:6s} {err}")


def main():
    os.environ.setdefault("TERM", "xterm")

    if not os.path.exists(AGY_ORIG):
        print("[ROTATOR] Install antigravity-cli first (agy.orig not found)", file=sys.stderr)
        sys.exit(1)

    agy_basename = os.path.basename(sys.argv[0]) if sys.argv[0] else "agy"

    if "--version" in sys.argv:
        print(f"Antigrafity Manager v{VERSION}")
        return

    if "--status" in sys.argv or "status" in sys.argv[1:2]:
        status()
        return

    if "--rotate" in sys.argv:
        result = rotate_and_retry(sys.argv[1:])
        if result:
            sys.exit(result.returncode)
        sys.exit(1)
        return

    # Default: pass through to agy.orig with rotated account
    result = rotate_and_retry(sys.argv[1:])
    if result:
        sys.exit(result.returncode)
    sys.exit(1)


if __name__ == "__main__":
    main()
